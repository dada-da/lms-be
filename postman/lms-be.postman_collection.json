    {
      "name": "Courses",
      "item": [
        {
          "name": "Create course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to Spring Boot\",\n  \"description\": \"A practical, project-based introduction to building REST APIs with Spring Boot 4.\",\n  \"thumbnailUrl\": \"https://example.com/images/spring-boot.png\",\n  \"price\": 29.99,\n  \"category\": \"PROGRAMMING\",\n  \"tags\": [\"java\", \"spring\", \"backend\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/course",
              "host": ["{{baseUrl}}"],
              "path": ["course"]
            }
          }
        },
        {
          "name": "Get course by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/course/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["course", "{{courseId}}"]
            }
          }
        },
        {
          "name": "List courses (optionally filter by status)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/course?status=PUBLISHED",
              "host": ["{{baseUrl}}"],
              "path": ["course"],
              "query": [
                {
                  "key": "status",
                  "value": "PUBLISHED",
                  "description": "DRAFT | PUBLISHED | ARCHIVED — omit to use role-based defaults"
                }
              ]
            }
          }
        },
        {
          "name": "Update course (patch)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot — Updated\",\n  \"description\": \"Now covering Spring Security and JWT.\",\n  \"price\": 34.99,\n  \"category\": \"PROGRAMMING\",\n  \"tags\": [\"java\", \"spring\", \"jwt\"],\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/course/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["course", "{{courseId}}"]
            }
          }
        },
        {
          "name": "Delete course",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/course/{{courseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["course", "{{courseId}}"]
            }
          }
        }
      ]
    },
